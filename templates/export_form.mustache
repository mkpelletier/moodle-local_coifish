{{!
    @template local_coifish/export_form

    Form on /local/coifish/export.php for selecting the date range and
    (in cohort mode) the cohort, and submitting to download a CSV of
    lecturer time commitments.

    Context variables required for this template:
    * formurl (string) - GET action URL of the form.
    * cancelurl (string) - URL for the Cancel button.
    * sesskey (string) - Current session key (CSRF guard on the download).
    * datefrom (string) - Current "from" date (YYYY-MM-DD or empty).
    * dateto (string) - Current "to" date (YYYY-MM-DD or empty).
    * hascohortfilter (bool) - Whether to show the cohort selector.
    * cohortlabel (string) - Label for the cohort selector.
    * cohortalllabel (string) - Label for the "all cohorts" option.
    * cohortoptions (array) - [{id, name, selected}] options for the cohort selector.

    Example context (json):
    {
        "formurl": "/local/coifish/export.php",
        "cancelurl": "/local/coifish/lecturerprofile.php",
        "sesskey": "abc123",
        "datefrom": "2026-01-01",
        "dateto": "2026-05-20",
        "hascohortfilter": true,
        "cohortlabel": "Cohort",
        "cohortalllabel": "All my cohorts",
        "cohortoptions": [
            {"id": 12, "name": "Theology PCs", "selected": false}
        ]
    }
}}
<div class="local-coifish-export-form">

    <div class="mb-4">
        <h4>
            <i class="fa fa-download me-2" aria-hidden="true"></i>
            {{#str}}export_title, local_coifish{{/str}}
        </h4>
        <p class="text-muted">{{#str}}export_desc, local_coifish{{/str}}</p>
    </div>

    <form method="get" action="{{formurl}}">
        <input type="hidden" name="download" value="1">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        {{#hascohortfilter}}
        <div class="form-group row mb-3">
            <label class="col-md-2 col-form-label" for="coifish-export-cohort">{{cohortlabel}}</label>
            <div class="col-md-4">
                <select name="cohortid" id="coifish-export-cohort" class="form-select">
                    <option value="0">{{cohortalllabel}}</option>
                    {{#cohortoptions}}
                    <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                    {{/cohortoptions}}
                </select>
            </div>
        </div>
        {{/hascohortfilter}}

        <div class="form-group row mb-3">
            <label class="col-md-2 col-form-label" for="coifish-export-datefrom">
                {{#str}}lecturer_filter_from, local_coifish{{/str}}
            </label>
            <div class="col-md-4">
                <input type="date" class="form-control" id="coifish-export-datefrom"
                       name="datefrom" value="{{datefrom}}" required>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-md-2 col-form-label" for="coifish-export-dateto">
                {{#str}}lecturer_filter_to, local_coifish{{/str}}
            </label>
            <div class="col-md-4">
                <input type="date" class="form-control" id="coifish-export-dateto"
                       name="dateto" value="{{dateto}}" required>
            </div>
        </div>

        <div class="form-group row">
            <div class="col-md-6">
                <button type="submit" class="btn btn-primary">
                    <i class="fa fa-download me-1" aria-hidden="true"></i>
                    {{#str}}export_download, local_coifish{{/str}}
                </button>
                <a href="{{cancelurl}}" class="btn btn-outline-secondary ms-2">
                    {{#str}}cancel, core{{/str}}
                </a>
            </div>
        </div>
    </form>

</div>
