{{!
    @template local_coifish/student_drilldown

    Student drill-down profile page.

    Shows full longitudinal detail for a single student including
    risk summary cards, prescriptive recommendations, and course history.

    Context variables required for this template:
    * userid (int) - The student user ID.
    * fullname (string) - The student's full name.
    * hasprofile (bool) - Whether a longitudinal profile exists.
    * profile (object) - The formatted profile data from the API.
    * recommendations (array) - Prescriptive recommendations.
    * hasrecommendations (bool) - Whether recommendations exist.
    * history (array) - Course snapshot history array.
    * hashistory (bool) - Whether course history exists.
    * current (array) - Current (in-progress) enrolment rows.
    * hascurrent (bool) - Whether current enrolment rows exist.
    * freshnesslabel (string) - Caption indicating how fresh the active snapshot data is.
    * refreshurl (string) - URL for the on-demand active-snapshot refresh.
    * backurl (string) - URL back to the risk overview.

    Example context (json):
    {
        "userid": 42,
        "fullname": "Jane Doe",
        "hasprofile": true,
        "profile": {
            "risklevel": "moderate",
            "risklabel": "Moderate risk",
            "isriskhigh": false,
            "isriskmoderate": true,
            "engagementpatternlabel": "Starts strong, fades mid-semester",
            "gradetrendlabel": "Declining",
            "interventionresponselabel": "Mixed response"
        },
        "hasrecommendations": true,
        "recommendations": [],
        "hashistory": true,
        "history": [],
        "backurl": "/local/coifish/index.php"
    }
}}
<div class="local-coifish-student-drilldown">

    {{! Back link }}
    <div class="mb-3">
        <a href="{{backurl}}" class="btn btn-sm btn-outline-secondary">
            <i class="fa fa-arrow-left me-1" aria-hidden="true"></i>
            {{#str}}back_to_overview, local_coifish{{/str}}
        </a>
    </div>

    {{#hasprofile}}

    {{! Profile summary cards }}
    {{#profile}}
    <div class="row g-3 mb-4">
        {{! Risk level }}
        <div class="col-sm-6 col-lg-3">
            <div class="card text-center h-100
                {{#isriskhigh}}border-danger{{/isriskhigh}}
                {{#isriskmoderate}}border-warning{{/isriskmoderate}}
                {{#isrisklow}}border-success{{/isrisklow}}
            ">
                <div class="card-body py-2">
                    <div class="text-muted small">{{#str}}profile_early_warning, local_coifish{{/str}}</div>
                    <div class="fs-4 fw-bold
                        {{#isriskhigh}}text-danger{{/isriskhigh}}
                        {{#isriskmoderate}}text-warning{{/isriskmoderate}}
                        {{#isrisklow}}text-success{{/isrisklow}}
                    ">{{risklabel}}</div>
                </div>
            </div>
        </div>

        {{! Engagement pattern }}
        <div class="col-sm-6 col-lg-3">
            <div class="card text-center h-100">
                <div class="card-body py-2">
                    <div class="text-muted small">{{#str}}profile_engagement_pattern, local_coifish{{/str}}</div>
                    <div class="fs-6 fw-semibold">{{engagementpatternlabel}}</div>
                </div>
            </div>
        </div>

        {{! Grade trend }}
        {{#gradetrendlabel}}
        <div class="col-sm-6 col-lg-3">
            <div class="card text-center h-100">
                <div class="card-body py-2">
                    <div class="text-muted small">{{#str}}profile_academic_trajectory, local_coifish{{/str}}</div>
                    <div class="fs-6 fw-semibold">{{gradetrendlabel}}</div>
                </div>
            </div>
        </div>
        {{/gradetrendlabel}}

        {{! Intervention response }}
        {{#interventionresponselabel}}
        <div class="col-sm-6 col-lg-3">
            <div class="card text-center h-100">
                <div class="card-body py-2">
                    <div class="text-muted small">{{#str}}profile_intervention_history, local_coifish{{/str}}</div>
                    <div class="fs-6 fw-semibold">{{interventionresponselabel}}</div>
                </div>
            </div>
        </div>
        {{/interventionresponselabel}}
    </div>

    {{! Risk factors }}
    {{#hasriskfactors}}
    <div class="mb-3">
        {{#riskfactors}}
            <span class="badge
                {{#isriskhigh}}bg-danger{{/isriskhigh}}
                {{#isriskmoderate}}bg-warning text-dark{{/isriskmoderate}}
                {{^isriskhigh}}{{^isriskmoderate}}bg-secondary{{/isriskmoderate}}{{/isriskhigh}}
                me-1 mb-1">
                <i class="fa fa-exclamation-triangle me-1" aria-hidden="true"></i>{{.}}
            </span>
        {{/riskfactors}}
    </div>
    {{/hasriskfactors}}

    {{! Additional metrics }}
    {{#avggrade}}
    <div class="small text-muted mb-3">
        <span class="me-3"><strong>{{#str}}drilldown_avg_grade, local_coifish{{/str}}:</strong> {{avggrade}}%</span>
        {{#avgsocial}}<span class="me-3"><strong>{{#str}}profile_social_presence, local_coifish{{/str}}:</strong> {{avgsocial}}%</span>{{/avgsocial}}
        {{#avgselfregulation}}<span class="me-3"><strong>{{#str}}profile_selfregulation, local_coifish{{/str}}:</strong> {{avgselfregulation}}%</span>{{/avgselfregulation}}
        {{#avgfeedbackpct}}<span><strong>{{#str}}drilldown_avg_feedback, local_coifish{{/str}}:</strong> {{avgfeedbackpct}}%</span>{{/avgfeedbackpct}}
    </div>
    {{/avggrade}}
    {{/profile}}

    {{! Recommendations }}
    {{#hasrecommendations}}
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="fa fa-lightbulb-o me-1" aria-hidden="true"></i>
                {{#str}}drilldown_recommendations, local_coifish{{/str}}
            </h5>
        </div>
        <div class="card-body">
            {{#recommendations}}
                <div class="d-flex align-items-start mb-2 py-2 px-3 rounded alert alert-{{severity}}">
                    <i class="fa fa-{{icon}} me-2 mt-1" aria-hidden="true"></i>
                    <span class="small">{{text}}</span>
                </div>
            {{/recommendations}}
        </div>
    </div>
    {{/hasrecommendations}}

    {{! Current enrolments }}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0">
                <i class="fa fa-graduation-cap me-1" aria-hidden="true"></i>
                {{#str}}drilldown_current_enrolments, local_coifish{{/str}}
            </h5>
            <div class="small text-muted d-flex align-items-center gap-2">
                <span>{{freshnesslabel}}</span>
                <a href="{{refreshurl}}" class="btn btn-sm btn-outline-secondary">
                    <i class="fa fa-refresh me-1" aria-hidden="true"></i>
                    {{#str}}refresh_now, local_coifish{{/str}}
                </a>
            </div>
        </div>
        {{#hascurrent}}
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>{{#str}}col_course_name, local_coifish{{/str}}</th>
                            <th>{{#str}}col_term, local_coifish{{/str}}</th>
                            <th>{{#str}}col_start, local_coifish{{/str}}</th>
                            <th>{{#str}}col_end, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_grade_so_far, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_engagement, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_social, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_selfregulation, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_feedback, local_coifish{{/str}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#current}}
                        <tr>
                            <td><a href="{{viewurl}}" target="_blank" rel="noopener">{{coursename}}</a></td>
                            <td>{{termlabel}}</td>
                            <td class="text-nowrap">{{coursestartformatted}}</td>
                            <td class="text-nowrap">{{courseendformatted}}</td>
                            <td class="text-center">
                                {{#currentgrade}}{{currentgrade}}%{{/currentgrade}}
                                {{^currentgrade}}<span class="text-muted">-</span>{{/currentgrade}}
                            </td>
                            <td class="text-center">{{#engagement}}{{engagement}}%{{/engagement}}{{^engagement}}<span class="text-muted">-</span>{{/engagement}}</td>
                            <td class="text-center">{{#social}}{{social}}%{{/social}}{{^social}}<span class="text-muted">-</span>{{/social}}</td>
                            <td class="text-center">{{#selfregulation}}{{selfregulation}}%{{/selfregulation}}{{^selfregulation}}<span class="text-muted">-</span>{{/selfregulation}}</td>
                            <td class="text-center">{{#feedbackpct}}{{feedbackpct}}%{{/feedbackpct}}{{^feedbackpct}}<span class="text-muted">-</span>{{/feedbackpct}}</td>
                        </tr>
                        {{/current}}
                    </tbody>
                </table>
            </div>
        </div>
        {{/hascurrent}}
        {{^hascurrent}}
        <div class="card-body">
            <div class="text-muted small mb-0">
                <i class="fa fa-info-circle me-1" aria-hidden="true"></i>
                {{#str}}drilldown_no_current_enrolments, local_coifish{{/str}}
            </div>
        </div>
        {{/hascurrent}}
    </div>

    {{! Course history }}
    {{#hashistory}}
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="fa fa-history me-1" aria-hidden="true"></i>
                {{#str}}drilldown_course_history, local_coifish{{/str}}
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>{{#str}}col_course_name, local_coifish{{/str}}</th>
                            <th>{{#str}}col_term, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_grade, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_engagement, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_social, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_selfregulation, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_feedback, local_coifish{{/str}}</th>
                            <th class="text-center">{{#str}}col_interventions, local_coifish{{/str}}</th>
                            <th>{{#str}}col_date, local_coifish{{/str}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#history}}
                        <tr>
                            <td><a href="{{viewurl}}" target="_blank" rel="noopener">{{coursename}}</a></td>
                            <td>{{termlabel}}</td>
                            <td class="text-center">
                                {{#finalgrade}}{{finalgrade}}%{{/finalgrade}}
                                {{^finalgrade}}<span class="text-muted">-</span>{{/finalgrade}}
                            </td>
                            <td class="text-center">{{engagement}}%</td>
                            <td class="text-center">{{social}}%</td>
                            <td class="text-center">{{selfregulation}}%</td>
                            <td class="text-center">{{feedbackpct}}%</td>
                            <td class="text-center">
                                {{interventioncount}}
                                {{#interventionsimproved}}
                                    <span class="text-success small">({{interventionsimproved}} <i class="fa fa-arrow-up" aria-hidden="true"></i>)</span>
                                {{/interventionsimproved}}
                            </td>
                            <td class="text-nowrap">{{courseenddateformatted}}</td>
                        </tr>
                        {{/history}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {{/hashistory}}

    {{^hashistory}}
    <div class="alert alert-info d-flex align-items-center">
        <i class="fa fa-info-circle me-2" aria-hidden="true"></i>
        {{#str}}drilldown_no_history, local_coifish{{/str}}
    </div>
    {{/hashistory}}

    {{/hasprofile}}

    {{^hasprofile}}
    <div class="alert alert-info d-flex align-items-center">
        <i class="fa fa-info-circle me-2" aria-hidden="true"></i>
        {{#str}}profile_no_data, local_coifish{{/str}}
    </div>
    {{/hasprofile}}

</div>
