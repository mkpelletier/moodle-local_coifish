{{!
    @template local_coifish/risk_overview

    Institution-wide student risk overview page.

    Displays a filterable list of at-risk students with summary statistics
    and links to individual student drill-down profiles.

    Context variables required for this template:
    * hasstudents (bool) - Whether any at-risk students matched the filters.
    * totalcount (int) - Total at-risk count across the filtered population.
    * highcount (int) - High-risk count.
    * moderatecount (int) - Moderate-risk count.
    * tablehtml (string) - Pre-rendered dynamic-table markup (raw HTML).
    * filteroptions (array) - Options for the category/cohort dropdown.
    * filterlabel (string) - Dropdown label.
    * filteralllabel (string) - "All" option label.
    * filterparamname (string) - Form param name (categoryid or cohortid).
    * selectedfilter (int) - Currently selected category/cohort ID.
    * selectedrisklevel (string) - Currently selected risk level.
    * isriskall / isriskhigh / isriskmoderate (bool) - Which risk option is selected.
    * selectedenrolstatus (string) - Currently selected enrolment status.
    * isenrolall / isenrolcurrent / isenrolnotenrolled (bool) - Which enrol option is selected.
    * formurl (string) - Filter form action URL.

    Example context (json):
    {
        "hasstudents": true,
        "totalcount": 12,
        "highcount": 5,
        "moderatecount": 7,
        "tablehtml": "<table>...</table>",
        "filteroptions": [],
        "filterlabel": "Course category",
        "filteralllabel": "All categories",
        "filterparamname": "categoryid",
        "selectedfilter": 0,
        "selectedrisklevel": "all",
        "isriskall": true,
        "isriskhigh": false,
        "isriskmoderate": false,
        "selectedenrolstatus": "current",
        "isenrolall": false,
        "isenrolcurrent": true,
        "isenrolnotenrolled": false,
        "formurl": "/local/coifish/index.php"
    }
}}
<div class="local-coifish-risk-overview">

    {{! Filter bar }}
    <form method="get" action="{{formurl}}" class="mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-sm-4 col-lg-3">
                <label for="coifish-org-filter" class="form-label small text-muted">
                    {{filterlabel}}
                </label>
                <select name="{{filterparamname}}" id="coifish-org-filter" class="form-select form-select-sm">
                    <option value="0">{{filteralllabel}}</option>
                    {{#filteroptions}}
                        <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                    {{/filteroptions}}
                </select>
            </div>
            <div class="col-sm-4 col-lg-3">
                <label for="coifish-risk-filter" class="form-label small text-muted">
                    {{#str}}filter_risk_level, local_coifish{{/str}}
                </label>
                <select name="risklevel" id="coifish-risk-filter" class="form-select form-select-sm">
                    <option value="all" {{#isriskall}}selected{{/isriskall}}>{{#str}}filter_risk_all, local_coifish{{/str}}</option>
                    <option value="high" {{#isriskhigh}}selected{{/isriskhigh}}>{{#str}}filter_risk_high, local_coifish{{/str}}</option>
                    <option value="moderate" {{#isriskmoderate}}selected{{/isriskmoderate}}>{{#str}}filter_risk_moderate, local_coifish{{/str}}</option>
                </select>
            </div>
            <div class="col-sm-4 col-lg-3">
                <label for="coifish-enrol-filter" class="form-label small text-muted">
                    {{#str}}filter_enrolment, local_coifish{{/str}}
                </label>
                <select name="enrolstatus" id="coifish-enrol-filter" class="form-select form-select-sm">
                    <option value="current" {{#isenrolcurrent}}selected{{/isenrolcurrent}}>{{#str}}filter_enrolment_current, local_coifish{{/str}}</option>
                    <option value="all" {{#isenrolall}}selected{{/isenrolall}}>{{#str}}filter_enrolment_all, local_coifish{{/str}}</option>
                    <option value="notenrolled" {{#isenrolnotenrolled}}selected{{/isenrolnotenrolled}}>{{#str}}filter_enrolment_notenrolled, local_coifish{{/str}}</option>
                </select>
            </div>
            <div class="col-sm-4 col-lg-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="fa fa-filter me-1" aria-hidden="true"></i>
                    {{#str}}filter_apply, local_coifish{{/str}}
                </button>
            </div>
        </div>
    </form>

    {{! Summary cards }}
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card text-center h-100">
                <div class="card-body py-3">
                    <div class="text-muted small">{{#str}}summary_total_atrisk, local_coifish{{/str}}</div>
                    <div class="fs-2 fw-bold">{{totalcount}}</div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card text-center h-100 border-danger">
                <div class="card-body py-3">
                    <div class="text-muted small">{{#str}}summary_high_risk, local_coifish{{/str}}</div>
                    <div class="fs-2 fw-bold text-danger">{{highcount}}</div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card text-center h-100 border-warning">
                <div class="card-body py-3">
                    <div class="text-muted small">{{#str}}summary_moderate_risk, local_coifish{{/str}}</div>
                    <div class="fs-2 fw-bold text-warning">{{moderatecount}}</div>
                </div>
            </div>
        </div>
    </div>

    {{! Student table — paginated, sortable dynamic table; AJAX refresh via core_table/dynamic. }}
    {{#hasstudents}}
    <div class="card">
        <div class="card-body p-0">
            {{{tablehtml}}}
        </div>
    </div>
    {{/hasstudents}}

    {{^hasstudents}}
    <div class="alert alert-info d-flex align-items-center">
        <i class="fa fa-info-circle me-2" aria-hidden="true"></i>
        {{#str}}no_atrisk_students, local_coifish{{/str}}
    </div>
    {{/hasstudents}}

</div>
