{{!
    @template local_coifish/lecturer_list

    Lecturer list overview page.

    Displays all lecturers with key performance metrics and links
    to individual lecturer profile pages. Filterable by course category.

    Context variables required for this template:
    * haslecturers (bool) - Whether any lecturer profiles exist at all (drives empty state).
    * tablehtml (string) - Pre-rendered dynamic-table markup (raw HTML).
    * filteroptions (array) - Options for the category/cohort dropdown.
    * filterlabel (string) - Dropdown label.
    * filteralllabel (string) - "All" option label.
    * filterparamname (string) - Form param name (categoryid or cohortid).
    * selectedfilter (int) - Currently selected filter ID.
    * formurl (string) - Filter form action URL.
    * exporturl (string) - URL to the CSV export page.

    Example context (json):
    {
        "haslecturers": true,
        "tablehtml": "<table>...</table>",
        "filteroptions": [],
        "filterlabel": "Course category",
        "filteralllabel": "All categories",
        "filterparamname": "categoryid",
        "selectedfilter": 0,
        "formurl": "/local/coifish/lecturerprofile.php",
        "exporturl": "/local/coifish/export.php"
    }
}}
<div class="local-coifish-lecturer-list">

    {{! Category filter }}
    <form method="get" action="{{formurl}}" class="mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-sm-5 col-lg-4">
                <label for="coifish-lect-org-filter" class="form-label small text-muted">
                    {{filterlabel}}
                </label>
                <select name="{{filterparamname}}" id="coifish-lect-org-filter" class="form-select form-select-sm">
                    <option value="0">{{filteralllabel}}</option>
                    {{#filteroptions}}
                        <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                    {{/filteroptions}}
                </select>
            </div>
            <div class="col-sm-3 col-lg-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="fa fa-filter me-1" aria-hidden="true"></i>
                    {{#str}}filter_apply, local_coifish{{/str}}
                </button>
            </div>
        </div>
    </form>

    {{! Export link }}
    <div class="mb-3">
        <a href="{{exporturl}}" class="btn btn-outline-secondary btn-sm">
            <i class="fa fa-download me-1" aria-hidden="true"></i>
            {{#str}}export_link, local_coifish{{/str}}
        </a>
    </div>

    {{! Lecturer table — paginated, sortable dynamic table; AJAX refresh via core_table/dynamic. }}
    {{#haslecturers}}
    <div class="card">
        <div class="card-body p-0">
            {{{tablehtml}}}
        </div>
    </div>
    {{/haslecturers}}

    {{^haslecturers}}
    <div class="alert alert-info d-flex align-items-center">
        <i class="fa fa-info-circle me-2" aria-hidden="true"></i>
        {{#str}}no_lecturer_profiles, local_coifish{{/str}}
    </div>
    {{/haslecturers}}

</div>
